{
  "openapi": "3.0.1",
  "info": {
    "title": "Demo API",
    "version": "v1"
  },
  "paths": {
    "/api/Person/GetPersons": {
      "get": {
        "tags": [
          "Person"
        ],
        "summary": "Get All Persons",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Person/GetPersonById/{id}": {
      "get": {
        "tags": [
          "Person"
        ],
        "summary": "Get a specific person",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "unique identifier",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Person/GetFirstNames": {
      "get": {
        "tags": [
          "Person"
        ],
        "summary": "Get all people's first names",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Person/PostPerson": {
      "post": {
        "tags": [
          "Person"
        ],
        "summary": "Add a person to the list of persons",
        "parameters": [
          {
            "name": "FirstName",
            "in": "query",
            "description": "first name of person",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "LastName",
            "in": "query",
            "description": "last name of person",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Person/UpdatePerson": {
      "put": {
        "tags": [
          "Person"
        ],
        "summary": "Update a person from the list of persons",
        "requestBody": {
          "description": "person's updated info",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PersonModel"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/PersonModel"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/PersonModel"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Person/DeletePerson/{id}": {
      "delete": {
        "tags": [
          "Person"
        ],
        "summary": "Delete a person from the list of people",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "unique identifier",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Person/GetNamesFromWcfService": {
      "get": {
        "tags": [
          "Person"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "PersonModel": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int32"
          },
          "firstName": {
            "type": "string",
            "nullable": true
          },
          "lastName": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    }
  }
}